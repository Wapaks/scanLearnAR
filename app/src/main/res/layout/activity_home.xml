<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scan &amp; Learn AR"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Interactive Object Learning"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_badge_yellow"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:text="Welcome, Student!"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Scrollable centered content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:padding="24dp"
            android:minHeight="400dp">

            <!-- Explorer Mode -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExplorer"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🔍  Explorer Mode"
                android:textSize="16sp"
                android:backgroundTint="@color/explorer"
                app:cornerRadius="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scan any object and learn at your own pace"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="20dp" />

            <!-- Mission Mode -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMission"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🎯  Mission Mode"
                android:textSize="16sp"
                android:backgroundTint="@color/mission"
                app:cornerRadius="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Complete specific learning objectives"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="20dp" />

            <!-- Challenge Mode -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChallenge"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="⚡  Challenge Mode"
                android:textSize="16sp"
                android:backgroundTint="@color/challenge"
                app:cornerRadius="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Timed quizzes and competitions"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="32dp" />

            <!-- Progress -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProgress"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="View My Progress"
                android:textSize="15sp"
                app:strokeColor="@color/primary"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>